// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum ChatType {
  PRIVATE
  GROUP
}

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  phone           String?   @unique
  googleId        String?   @unique
  username        String    @unique
  name            String
  avatarUrl       String?
  status          String?   @default("Hey there! I am using Starosta Messenger")
  passwordHash    String?
  isOnline        Boolean   @default(false)
  lastSeen        DateTime  @default(now())
  fcmToken        String?
  isVerified      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sentMessages    Message[] @relation("SentMessages")
  chatMembers     ChatMember[]
  createdChats    Chat[]    @relation("CreatedChats")
  refreshTokens   RefreshToken[]
  pinnedMessages  PinnedMessage[]
  readReceipts    MessageRead[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Chat {
  id          String     @id @default(cuid())
  type        ChatType   @default(PRIVATE)
  name        String?
  avatarUrl   String?
  createdById String
  createdBy   User       @relation("CreatedChats", fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  members     ChatMember[]
  messages    Message[]
  pinnedMessages PinnedMessage[]

  @@map("chats")
}

model ChatMember {
  id        String   @id @default(cuid())
  chatId    String
  userId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAdmin   Boolean  @default(false)
  joinedAt  DateTime @default(now())

  @@unique([chatId, userId])
  @@map("chat_members")
}

model Message {
  id          String        @id @default(cuid())
  chatId      String
  senderId    String
  chat        Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender      User          @relation("SentMessages", fields: [senderId], references: [id])
  content     String?
  fileUrl     String?
  fileName    String?
  fileType    String?
  fileSize    Int?
  status      MessageStatus @default(SENT)
  isEdited    Boolean       @default(false)
  isDeleted   Boolean       @default(false)
  replyToId   String?
  replyTo     Message?      @relation("ReplyMessages", fields: [replyToId], references: [id])
  replies     Message[]     @relation("ReplyMessages")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  pinnedIn    PinnedMessage[]
  readBy      MessageRead[]

  @@map("messages")
}

model MessageRead {
  id         String   @id @default(cuid())
  messageId  String
  userId     String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt     DateTime @default(now())

  @@unique([messageId, userId])
  @@map("message_reads")
}

model PinnedMessage {
  id        String   @id @default(cuid())
  chatId    String
  messageId String
  pinnedById String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy  User     @relation(fields: [pinnedById], references: [id])
  createdAt DateTime @default(now())

  @@unique([chatId, messageId])
  @@map("pinned_messages")
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_codes")
}
